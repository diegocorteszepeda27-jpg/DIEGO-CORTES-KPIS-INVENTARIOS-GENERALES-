// Column indexes
const CI = {
  fecha:0,sku:1,desc:2,prov:3,suc:4,bod:5,
  stockSap:6,fisico:7,dif:8,valInv:9,valDif:10,
  motivo:11,mes:12,ano:13,cantSku:14,skuDif:15,
  venc:16,ubic:17
};

const MESES_ORDER = ['febrero','marzo','abril','mayo'];
const PALETTE = ['#4f9cf9','#f59e0b','#22c55e','#ef4444','#a78bfa','#14b8a6','#f0a500','#e05a2b','#ec4899','#06b6d4','#84cc16','#f97316','#8b5cf6','#10b981','#fb923c','#6366f1'];

let allRows = EMBEDDED.rows;
let filteredRows = allRows;
let charts = {};
let skuPage = 0, skuSortCol = -1, skuSortDir = 1;

// ═══════════════════════════════════════════════════════
// INIT
// ═══════════════════════════════════════════════════════
window.onload = () => {
  populateFilters(allRows);
  applyFilters();
};

function showSection(id, btn) {
  document.querySelectorAll('.section').forEach(s => s.classList.remove('active'));
  document.querySelectorAll('.nav-tab').forEach(t => t.classList.remove('active'));
  document.getElementById('sec-' + id).classList.add('active');
  btn.classList.add('active');
  renderSection(id);
}

// ═══════════════════════════════════════════════════════
// FILTERS
// ═══════════════════════════════════════════════════════
function populateFilters(rows) {
  const uniq = (key) => [...new Set(rows.map(r => r[key]).filter(v => v && v !== ''))].sort();
  const fill = (id, vals, label) => {
    const el = document.getElementById(id);
    const cur = el.value;
    el.innerHTML = `<option value="">` + label + `</option>` + vals.map(v => `<option value="${v}" ${v===cur?'selected':''}>${v}</option>`).join('');
  };
  fill('fMes', MESES_ORDER.filter(m => uniq(CI.mes).includes(m)), 'Todos los meses');
  fill('fSucursal', uniq(CI.suc), 'Todas las sucursales');
  fill('fProveedor', uniq(CI.prov), 'Todos los proveedores');
  fill('fBodega', uniq(CI.bod), 'Todos los tipos de bodega');
  const motivos = uniq(CI.motivo).filter(m => m !== '45-SIN DIFERENCIAS ' && m !== 'SIN MOTIVO');
  fill('fMotivo', ['45-SIN DIFERENCIAS ', 'SIN MOTIVO', ...motivos], 'Todos los motivos');
}

function applyFilters() {
  const mes = document.getElementById('fMes').value;
  const suc = document.getElementById('fSucursal').value;
  const prov = document.getElementById('fProveedor').value;
  const bod = document.getElementById('fBodega').value;
  const mot = document.getElementById('fMotivo').value;

  filteredRows = allRows.filter(r =>
    (!mes  || r[CI.mes] === mes) &&
    (!suc  || r[CI.suc] === suc) &&
    (!prov || r[CI.prov] === prov) &&
    (!bod  || r[CI.bod] === bod) &&
    (!mot  || r[CI.motivo] === mot)
  );

  document.getElementById('filterCount').textContent = filteredRows.length.toLocaleString('es-CL') + ' registros';
  skuPage = 0; skuSortCol = -1;

  // Find active section
  const activeId = document.querySelector('.section.active')?.id?.replace('sec-','') || 'kpis';
  renderSection(activeId);
}

function resetFilters() {
  ['fMes','fSucursal','fProveedor','fBodega','fMotivo'].forEach(id => document.getElementById(id).value = '');
  applyFilters();
}

function renderSection(id) {
  if (id === 'kpis') renderKPIs();
  else if (id === 'proveedores') renderProveedores();
  else if (id === 'bodegas') renderBodegas();
  else if (id === 'motivos') renderMotivos();
  else if (id === 'vencimientos') renderVencimientos();
  else if (id === 'detalle') renderSkuTable();
}

// ═══════════════════════════════════════════════════════
// HELPERS
// ═══════════════════════════════════════════════════════
function agg(rows) {
  let totalInv=0, totalDif=0, cantSku=0, skuDif=0, merma=0, venc=0;
  rows.forEach(r => {
    totalInv += +r[CI.valInv]||0;
    totalDif += +r[CI.valDif]||0;
    cantSku  += +r[CI.cantSku]||0;
    skuDif   += +r[CI.skuDif]||0;
    const bod = (r[CI.bod]||'').toUpperCase();
    if(bod.includes('MERMA')) merma += +r[CI.valInv]||0;
    if(bod.includes('VENCID')) venc += +r[CI.valInv]||0;
  });
  const difPct  = totalInv ? (totalDif/totalInv)*100 : 0;
  const confPct = cantSku  ? (1 - skuDif/cantSku)*100 : 100;
  const mermaPct= totalInv ? (merma/totalInv)*100 : 0;
  const vencPct = totalInv ? (venc/totalInv)*100 : 0;
  return {totalInv,totalDif,cantSku,skuDif,merma,venc,difPct,confPct,mermaPct,vencPct};
}

function groupBy(rows, keyIdx) {
  const map = {};
  rows.forEach(r => {
    const k = r[keyIdx]||'SIN CLASIFICAR';
    if(!map[k]) map[k] = [];
    map[k].push(r);
  });
  return map;
}

const CLP = new Intl.NumberFormat('es-CL', {style:'currency', currency:'CLP', minimumFractionDigits:0, maximumFractionDigits:0});
const CLPM = new Intl.NumberFormat('es-CL', {minimumFractionDigits:0, maximumFractionDigits:0});

const fmt = {
  clp:  v => CLP.format(Math.round(+v)),
  clpM: v => {
    const m = +v / 1e6;
    return (m >= 0 ? '' : '-') + '$ ' + Math.abs(m).toFixed(2).replace('.',',') + ' M';
  },
  clpK: v => {
    const k = +v / 1e3;
    return (k >= 0 ? '' : '-') + '$ ' + Math.abs(k).toFixed(1).replace('.',',') + ' K';
  },
  pct: v => v.toFixed(2) + '%',
  n:   v => CLPM.format(+v),
  // Auto-scale: use M if ≥ 1M, K if ≥ 1K, else full CLP
  auto: v => {
    const abs = Math.abs(+v);
    if(abs >= 1e6) return fmt.clpM(v);
    if(abs >= 1e3) return fmt.clpK(v);
    return fmt.clp(v);
  }
};

function destroyChart(id) {
  if(charts[id]) { try{ charts[id].destroy(); }catch(e){} delete charts[id]; }
}

function mkChart(id, cfg) {
  destroyChart(id);
  const ctx = document.getElementById(id);
  if(!ctx) return;
  // Apply dark defaults
  Chart.defaults.color = '#94a3b8';
  Chart.defaults.borderColor = 'rgba(42,58,85,.5)';
  charts[id] = new Chart(ctx, cfg);
}

