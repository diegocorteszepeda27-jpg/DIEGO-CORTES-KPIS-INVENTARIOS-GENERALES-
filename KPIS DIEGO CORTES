<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>Dashboard KPIs Inventarios – Allendes Hermanos</title>
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/xlsx/dist/xlsx.full.min.js"></script>
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=IBM+Plex+Mono:wght@400;500&family=IBM+Plex+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
:root{
  --bg:#0b0f1a;--surface:#111827;--surface2:#1a2236;--surface3:#222d45;
  --border:#2a3a55;--border2:#1e2d46;
  --accent:#f0a500;--accent2:#e05a2b;--blue:#4f9cf9;--green:#22c55e;
  --red:#ef4444;--yellow:#f59e0b;--purple:#a78bfa;--teal:#14b8a6;
  --text:#e2e8f0;--text2:#94a3b8;--text3:#4a5568;
  --ok-bg:rgba(34,197,94,.12);--ok-c:#22c55e;--ok-b:rgba(34,197,94,.25);
  --fail-bg:rgba(239,68,68,.12);--fail-c:#ef4444;--fail-b:rgba(239,68,68,.25);
}
*{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth}
body{font-family:'IBM Plex Sans',sans-serif;background:var(--bg);color:var(--text);min-height:100vh;overflow-x:hidden}

/* NAV */
nav{background:var(--surface);border-bottom:1px solid var(--border);height:58px;display:flex;align-items:center;padding:0 24px;gap:16px;position:sticky;top:0;z-index:200}
.nav-brand{display:flex;align-items:center;gap:10px}
.nav-icon{width:34px;height:34px;background:linear-gradient(135deg,var(--accent),var(--accent2));border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:16px;flex-shrink:0}
.nav-title{font-family:'Syne',sans-serif;font-weight:800;font-size:15px;letter-spacing:-.3px}
.nav-title span{color:var(--accent)}
.nav-sub{font-size:10px;color:var(--text2);font-family:'IBM Plex Mono',monospace;letter-spacing:.5px}
.nav-right{margin-left:auto;display:flex;align-items:center;gap:10px}
.nav-tabs{display:flex;gap:2px;margin-left:32px}
.nav-tab{padding:6px 14px;border-radius:6px;font-size:12px;font-family:'IBM Plex Mono',monospace;cursor:pointer;border:none;background:transparent;color:var(--text2);transition:.2s;letter-spacing:.3px}
.nav-tab:hover{background:var(--surface2);color:var(--text)}
.nav-tab.active{background:rgba(79,156,249,.15);color:var(--blue);border:1px solid rgba(79,156,249,.25)}
.badge-update{font-size:10px;background:var(--surface2);color:var(--text2);border:1px solid var(--border);border-radius:20px;padding:3px 10px;font-family:'IBM Plex Mono',monospace}

/* FILTERS */
.filter-strip{background:var(--surface2);border-bottom:1px solid var(--border);padding:10px 24px;display:flex;gap:10px;align-items:center;flex-wrap:wrap}
.filter-label{font-size:10px;color:var(--text3);font-family:'IBM Plex Mono',monospace;letter-spacing:1px;text-transform:uppercase;white-space:nowrap}
select{background:var(--surface);color:var(--text);border:1px solid var(--border);border-radius:7px;padding:7px 12px;font-family:'IBM Plex Sans',sans-serif;font-size:12px;cursor:pointer;outline:none;min-width:140px;max-width:200px}
select:focus{border-color:var(--accent)}
.btn{padding:7px 14px;border-radius:7px;border:none;font-family:'Syne',sans-serif;font-weight:700;font-size:11px;cursor:pointer;display:flex;align-items:center;gap:5px;white-space:nowrap}
.btn-primary{background:var(--accent);color:#000}
.btn-primary:hover{opacity:.85}
.btn-outline{background:transparent;color:var(--text2);border:1px solid var(--border)}
.btn-outline:hover{background:var(--surface3);color:var(--text)}
.btn-green{background:rgba(34,197,94,.15);color:var(--green);border:1px solid rgba(34,197,94,.25)}
.btn-green:hover{background:rgba(34,197,94,.25)}
.filter-count{font-size:11px;color:var(--text2);font-family:'IBM Plex Mono',monospace;margin-left:auto}

/* UPLOAD ZONE */
.upload-zone{margin:20px 24px;border:2px dashed var(--border);border-radius:12px;padding:20px 24px;display:flex;align-items:center;gap:16px;background:var(--surface);cursor:pointer;transition:.2s}
.upload-zone:hover,.upload-zone.drag{border-color:var(--accent);background:rgba(240,165,0,.04)}
.up-icon{width:40px;height:40px;background:rgba(240,165,0,.1);border-radius:9px;display:flex;align-items:center;justify-content:center;font-size:18px;flex-shrink:0}
.up-text h3{font-family:'Syne',sans-serif;font-size:13px;font-weight:700}
.up-text p{font-size:11px;color:var(--text2);font-family:'IBM Plex Mono',monospace;margin-top:2px}
.file-ok{font-size:11px;color:var(--green);font-family:'IBM Plex Mono',monospace;background:rgba(34,197,94,.08);border:1px solid rgba(34,197,94,.2);border-radius:5px;padding:3px 9px}

/* MAIN */
.main{padding:20px 24px 40px}
.section{display:none}
.section.active{display:block}

/* KPI GRID */
.kpi-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:14px;margin-bottom:20px}
@media(max-width:900px){.kpi-grid{grid-template-columns:repeat(2,1fr)}}
.kpi-card{background:var(--surface);border:1px solid var(--border);border-radius:12px;padding:18px 20px;position:relative;overflow:hidden;animation:fadeUp .4s ease both}
.kpi-card::after{content:'';position:absolute;top:0;left:0;right:0;height:3px;border-radius:12px 12px 0 0}
.kpi-card.c-red::after{background:var(--red)}.kpi-card.c-blue::after{background:var(--blue)}
.kpi-card.c-yellow::after{background:var(--yellow)}.kpi-card.c-green::after{background:var(--green)}
.kpi-card.c-purple::after{background:var(--purple)}
.kpi-lbl{font-size:10px;color:var(--text2);font-family:'IBM Plex Mono',monospace;letter-spacing:.8px;text-transform:uppercase;margin-bottom:8px}
.kpi-val{font-family:'Syne',sans-serif;font-size:30px;font-weight:800;line-height:1;margin-bottom:6px}
.c-red .kpi-val{color:var(--red)}.c-blue .kpi-val{color:var(--blue)}
.c-yellow .kpi-val{color:var(--yellow)}.c-green .kpi-val{color:var(--green)}
.c-purple .kpi-val{color:var(--purple)}
.kpi-badge{display:inline-flex;align-items:center;gap:4px;padding:3px 8px;border-radius:20px;font-size:10px;font-family:'IBM Plex Mono',monospace}
.badge-ok{background:var(--ok-bg);color:var(--ok-c);border:1px solid var(--ok-b)}
.badge-fail{background:var(--fail-bg);color:var(--fail-c);border:1px solid var(--fail-b)}
.kpi-meta{font-size:10px;color:var(--text3);font-family:'IBM Plex Mono',monospace;margin-top:5px}

/* SUMMARY ROW */
.summary-row{display:flex;gap:12px;margin-bottom:20px;flex-wrap:wrap}
.sum-pill{background:var(--surface2);border:1px solid var(--border2);border-radius:8px;padding:10px 16px;font-family:'IBM Plex Mono',monospace;font-size:12px;display:flex;flex-direction:column;gap:2px;flex:1;min-width:120px}
.sum-pill .sp-lbl{font-size:9px;color:var(--text3);text-transform:uppercase;letter-spacing:.8px}
.sum-pill .sp-val{font-size:15px;font-weight:600;color:var(--text)}
.sum-pill .sp-val.pos{color:var(--green)}.sum-pill .sp-val.neg{color:var(--red)}.sum-pill .sp-val.warn{color:var(--yellow)}

/* CHART GRID */
.chart-grid{display:grid;gap:14px;margin-bottom:20px}
.cg-2{grid-template-columns:1fr 1fr}
.cg-3{grid-template-columns:2fr 1fr}
.cg-full{grid-template-columns:1fr}
@media(max-width:800px){.cg-2,.cg-3{grid-template-columns:1fr}}
.chart-card{background:var(--surface);border:1px solid var(--border);border-radius:12px;padding:18px 20px;animation:fadeUp .45s ease both}
.chart-ttl{font-family:'Syne',sans-serif;font-size:12px;font-weight:700;color:var(--text2);text-transform:uppercase;letter-spacing:.5px;margin-bottom:14px;display:flex;align-items:center;gap:8px}
.chart-ttl::before{content:'';width:3px;height:13px;border-radius:2px;background:var(--accent);flex-shrink:0}
.chart-ttl.blue::before{background:var(--blue)}.chart-ttl.green::before{background:var(--green)}
.chart-ttl.red::before{background:var(--red)}.chart-ttl.purple::before{background:var(--purple)}
.chart-ttl.teal::before{background:var(--teal)}
.chart-wrap{position:relative;height:230px}
.chart-wrap.tall{height:280px}
.chart-wrap.sm{height:180px}

/* TABLES */
.tbl-card{background:var(--surface);border:1px solid var(--border);border-radius:12px;overflow:hidden;margin-bottom:20px;animation:fadeUp .5s ease both}
.tbl-head{padding:14px 18px;display:flex;align-items:center;gap:10px;border-bottom:1px solid var(--border);flex-wrap:wrap}
.tbl-ttl{font-family:'Syne',sans-serif;font-size:12px;font-weight:700;color:var(--text2);text-transform:uppercase;letter-spacing:.5px;display:flex;align-items:center;gap:7px}
.tbl-ttl::before{content:'';width:3px;height:13px;border-radius:2px;background:var(--green);flex-shrink:0}
.tbl-cnt{font-size:10px;color:var(--text3);font-family:'IBM Plex Mono',monospace;margin-left:auto}
.tbl-wrap{overflow-x:auto;max-height:380px;overflow-y:auto}
table{width:100%;border-collapse:collapse;font-size:11px}
thead{position:sticky;top:0;z-index:2}
th{background:var(--surface2);color:var(--text2);font-family:'IBM Plex Mono',monospace;font-size:9px;font-weight:500;letter-spacing:.8px;text-transform:uppercase;padding:9px 13px;text-align:left;border-bottom:1px solid var(--border);white-space:nowrap;cursor:pointer;user-select:none}
th:hover{color:var(--accent)}
td{padding:8px 13px;border-bottom:1px solid rgba(42,58,85,.4);font-family:'IBM Plex Mono',monospace;color:var(--text);white-space:nowrap;max-width:260px;overflow:hidden;text-overflow:ellipsis}
tr:hover td{background:rgba(255,255,255,.02)}
.td-neg{color:var(--red);font-weight:500}.td-pos{color:var(--green);font-weight:500}.td-zero{color:var(--text3)}
.td-tag{display:inline-flex;padding:2px 7px;border-radius:20px;font-size:9px}
.tag-ok{background:var(--ok-bg);color:var(--ok-c);border:1px solid var(--ok-b)}
.tag-fail{background:var(--fail-bg);color:var(--fail-c);border:1px solid var(--fail-b)}
.tag-warn{background:rgba(245,158,11,.1);color:var(--yellow);border:1px solid rgba(245,158,11,.2)}
.tag-info{background:rgba(79,156,249,.1);color:var(--blue);border:1px solid rgba(79,156,249,.2)}

/* SEARCH */
.search-box{background:var(--surface2);border:1px solid var(--border);border-radius:7px;padding:6px 12px;color:var(--text);font-family:'IBM Plex Sans',sans-serif;font-size:12px;outline:none;width:220px}
.search-box:focus{border-color:var(--accent)}

/* PAGINATION */
.pagination{display:flex;align-items:center;gap:8px;padding:12px 18px;border-top:1px solid var(--border);font-size:11px;font-family:'IBM Plex Mono',monospace;color:var(--text2)}
.page-btn{background:var(--surface2);border:1px solid var(--border);color:var(--text);border-radius:5px;padding:4px 10px;cursor:pointer;font-size:11px;font-family:'IBM Plex Mono',monospace}
.page-btn:hover{border-color:var(--accent);color:var(--accent)}
.page-btn:disabled{opacity:.3;cursor:default}
.page-info{margin:0 8px}

/* ANIMATIONS */
@keyframes fadeUp{from{opacity:0;transform:translateY(14px)}to{opacity:1;transform:translateY(0)}}

/* VENCIMIENTO BADGES */
.vbadge{display:inline-flex;align-items:center;gap:4px;padding:3px 9px;border-radius:20px;font-size:10px;font-family:'IBM Plex Mono',monospace;font-weight:500;white-space:nowrap}
.vb-expired{background:rgba(239,68,68,.18);color:#f87171;border:1px solid rgba(239,68,68,.35)}
.vb-critico{background:rgba(239,68,68,.12);color:#ef4444;border:1px solid rgba(239,68,68,.25)}
.vb-alerta{background:rgba(245,158,11,.12);color:#f59e0b;border:1px solid rgba(245,158,11,.25)}
.vb-proximo{background:rgba(34,197,94,.10);color:#22c55e;border:1px solid rgba(34,197,94,.22)}
.vb-vigente{background:rgba(79,156,249,.10);color:#4f9cf9;border:1px solid rgba(79,156,249,.22)}
.venc-kpi{background:var(--surface);border:1px solid var(--border);border-radius:12px;padding:16px 18px;display:flex;flex-direction:column;gap:6px;position:relative;overflow:hidden}
.venc-kpi::after{content:'';position:absolute;top:0;left:0;right:0;height:3px;border-radius:12px 12px 0 0}
.venc-kpi.e::after{background:#f87171}.venc-kpi.c::after{background:var(--red)}
.venc-kpi.a::after{background:var(--yellow)}.venc-kpi.p::after{background:var(--green)}.venc-kpi.v::after{background:var(--blue)}
.venc-kpi .vk-lbl{font-size:9px;color:var(--text2);font-family:'IBM Plex Mono',monospace;letter-spacing:.8px;text-transform:uppercase}
.venc-kpi .vk-num{font-family:'Syne',sans-serif;font-size:26px;font-weight:800;line-height:1}
.venc-kpi.e .vk-num{color:#f87171}.venc-kpi.c .vk-num{color:var(--red)}
.venc-kpi.a .vk-num{color:var(--yellow)}.venc-kpi.p .vk-num{color:var(--green)}.venc-kpi.v .vk-num{color:var(--blue)}
.venc-kpi .vk-val{font-size:11px;color:var(--text2);font-family:'IBM Plex Mono',monospace}

/* SCROLLBAR */
::-webkit-scrollbar{width:5px;height:5px}
::-webkit-scrollbar-track{background:var(--bg)}
::-webkit-scrollbar-thumb{background:var(--border);border-radius:3px}
::-webkit-scrollbar-thumb:hover{background:var(--text3)}

/* SECTION TITLE */
.sec-title{font-family:'Syne',sans-serif;font-size:16px;font-weight:800;color:var(--text);margin-bottom:16px;display:flex;align-items:center;gap:10px}
.sec-title span{font-size:11px;font-family:'IBM Plex Mono',monospace;font-weight:400;color:var(--text2);background:var(--surface2);border:1px solid var(--border);border-radius:5px;padding:2px 8px}
</style>
</head>
<body>

<!-- NAV -->
<nav>
  <div class="nav-brand">
    <div class="nav-icon">🐾</div>
    <div>
      <div class="nav-title">Allendes <span>Hermanos</span></div>
      <div class="nav-sub">Dashboard KPIs Inventarios · Diego Cortés</div>
    </div>
  </div>
  <div class="nav-tabs">
    <button class="nav-tab active" onclick="showSection('kpis',this)">KPIs Globales</button>
    <button class="nav-tab" onclick="showSection('proveedores',this)">Proveedores</button>
    <button class="nav-tab" onclick="showSection('bodegas',this)">Bodegas</button>
    <button class="nav-tab" onclick="showSection('motivos',this)">Motivos</button>
    <button class="nav-tab" onclick="showSection('vencimientos',this)">🗓 Caducidades</button>
    <button class="nav-tab" onclick="showSection('detalle',this)">Detalle SKUs</button>
  </div>
  <div class="nav-right">
    <span class="badge-update" id="lastUpdate">BD: 28-05-2026</span>
  </div>
</nav>

<!-- FILTERS -->
<div class="filter-strip">
  <span class="filter-label">Filtros:</span>
  <select id="fMes" onchange="applyFilters()"><option value="">Todos los meses</option></select>
  <select id="fSucursal" onchange="applyFilters()"><option value="">Todas las sucursales</option></select>
  <select id="fProveedor" onchange="applyFilters()"><option value="">Todos los proveedores</option></select>
  <select id="fBodega" onchange="applyFilters()"><option value="">Todos los tipos de bodega</option></select>
  <select id="fMotivo" onchange="applyFilters()"><option value="">Todos los motivos</option></select>
  <button class="btn btn-outline" onclick="resetFilters()">✕ Limpiar</button>
  <button class="btn btn-primary" onclick="document.getElementById('fileInput').click()">↑ Actualizar BD</button>
  <input type="file" id="fileInput" accept=".xlsx,.xls" style="display:none" onchange="loadFile(event)">
  <span class="filter-count" id="filterCount"></span>
</div>

<!-- UPLOAD ZONE (shown when no data) -->
<div class="upload-zone" id="uploadZone" style="display:none" onclick="document.getElementById('fileInput').click()" ondragover="ev.preventDefault();this.classList.add('drag')" ondragleave="this.classList.remove('drag')" ondrop="ev.preventDefault();this.classList.remove('drag');if(ev.dataTransfer.files[0])loadFile({target:{files:ev.dataTransfer.files}})">
  <div class="up-icon">📊</div>
  <div class="up-text">
    <h3>Cargar BD_DATA_DASHBOARDS_FECHA_28-05-2026.xlsx</h3>
    <p>Arrastre el archivo o haga clic para seleccionar · Formato oficial Allendes Hermanos</p>
  </div>
  <button class="btn btn-primary" onclick="event.stopPropagation();document.getElementById('fileInput').click()">Seleccionar</button>
</div>

<!-- MAIN -->
<div class="main" id="mainContent">

  <!-- SECTION: KPIs -->
  <div class="section active" id="sec-kpis">
    <div class="sec-title">KPIs Globales Consolidados <span id="kpi-period-tag"></span></div>
    <div class="kpi-grid" id="kpiGrid"></div>
    <div class="summary-row" id="summaryRow"></div>
    <div class="chart-grid cg-2">
      <div class="chart-card"><div class="chart-ttl blue">Confiabilidad por Sucursal (%)</div><div class="chart-wrap"><canvas id="chartConfiSuc"></canvas></div></div>
      <div class="chart-card"><div class="chart-ttl red">% Diferencia por Sucursal</div><div class="chart-wrap"><canvas id="chartDifSuc"></canvas></div></div>
    </div>
    <div class="chart-grid cg-2">
      <div class="chart-card"><div class="chart-ttl green">Evolución Mensual · Confiabilidad %</div><div class="chart-wrap"><canvas id="chartMensual"></canvas></div></div>
      <div class="chart-card"><div class="chart-ttl">Valor Inventario por Mes ($ M)</div><div class="chart-wrap"><canvas id="chartInvMes"></canvas></div></div>
    </div>
  </div>

  <!-- SECTION: PROVEEDORES -->
  <div class="section" id="sec-proveedores">
    <div class="sec-title">Análisis por Proveedor <span id="prov-period-tag"></span></div>
    <div class="chart-grid cg-3">
      <div class="chart-card"><div class="chart-ttl purple">Participación en Diferencias por Proveedor</div><div class="chart-wrap tall"><canvas id="chartProvDif"></canvas></div></div>
      <div class="chart-card"><div class="chart-ttl">% Dif. por Proveedor (Top 10)</div><div class="chart-wrap tall"><canvas id="chartProvPct"></canvas></div></div>
    </div>
    <div class="tbl-card">
      <div class="tbl-head">
        <div class="tbl-ttl" style="--c:var(--purple)">Tabla Comparativa por Proveedor</div>
        <button class="btn btn-green" onclick="exportTable('provTable','proveedores')">↓ Exportar CSV</button>
      </div>
      <div class="tbl-wrap"><table id="provTable"></table></div>
    </div>
  </div>

  <!-- SECTION: BODEGAS -->
  <div class="section" id="sec-bodegas">
    <div class="sec-title">Comparativo por Tipo de Bodega</div>
    <div class="chart-grid cg-2">
      <div class="chart-card"><div class="chart-ttl teal">Distribución Valor Inventario por Bodega</div><div class="chart-wrap tall"><canvas id="chartBodegaPie"></canvas></div></div>
      <div class="chart-card"><div class="chart-ttl red">Diferencias por Tipo de Bodega</div><div class="chart-wrap tall"><canvas id="chartBodegaDif"></canvas></div></div>
    </div>
    <div class="tbl-card">
      <div class="tbl-head">
        <div class="tbl-ttl">Resumen por Tipo de Bodega</div>
        <button class="btn btn-green" onclick="exportTable('bodegaTable','bodegas')">↓ Exportar CSV</button>
      </div>
      <div class="tbl-wrap"><table id="bodegaTable"></table></div>
    </div>
  </div>

  <!-- SECTION: MOTIVOS -->
  <div class="section" id="sec-motivos">
    <div class="sec-title">Motivos de Diferencias</div>
    <div class="chart-grid cg-2">
      <div class="chart-card"><div class="chart-ttl red">Distribución por Motivo (# casos)</div><div class="chart-wrap tall"><canvas id="chartMotivoPie"></canvas></div></div>
      <div class="chart-card"><div class="chart-ttl">Valorizado por Motivo (M$)</div><div class="chart-wrap tall"><canvas id="chartMotivoBar"></canvas></div></div>
    </div>
    <div class="tbl-card">
      <div class="tbl-head">
        <div class="tbl-ttl">Detalle de Motivos</div>
        <button class="btn btn-green" onclick="exportTable('motivoTable','motivos')">↓ Exportar CSV</button>
      </div>
      <div class="tbl-wrap"><table id="motivoTable"></table></div>
    </div>
  </div>

  <!-- SECTION: VENCIMIENTOS -->
  <div class="section" id="sec-vencimientos">
    <div class="sec-title">Análisis de Fechas de Caducidad <span id="venc-period-tag"></span></div>
    <div class="kpi-grid" id="vencKpiGrid"></div>
    <div class="chart-grid cg-2">
      <div class="chart-card"><div class="chart-ttl red">Distribución por Urgencia</div><div class="chart-wrap"><canvas id="chartVencPie"></canvas></div></div>
      <div class="chart-card"><div class="chart-ttl yellow">Valor en Riesgo por Categoría ($ M)</div><div class="chart-wrap"><canvas id="chartVencVal"></canvas></div></div>
    </div>
    <div class="chart-grid cg-full">
      <div class="chart-card"><div class="chart-ttl blue">Próximos Vencimientos — SKUs por Mes de Caducidad</div><div class="chart-wrap"><canvas id="chartVencTimeline"></canvas></div></div>
    </div>
    <div class="tbl-card">
      <div class="tbl-head">
        <div class="tbl-ttl" style="--c:var(--red)">Detalle SKUs con Fecha de Vencimiento</div>
        <select id="vencFiltro" onchange="renderVencTable()" style="min-width:160px">
          <option value="">Todas las categorías</option>
          <option value="VENCIDO">⛔ Vencido</option>
          <option value="CRITICO">🔴 Crítico (≤30 días)</option>
          <option value="ALERTA">🟡 Alerta (31–90 días)</option>
