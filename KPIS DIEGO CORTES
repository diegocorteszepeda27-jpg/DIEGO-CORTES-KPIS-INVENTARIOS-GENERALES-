// ═══════════════════════════════════════════════════════
let skuFiltered = [];
const PAGE_SIZE = 100;

function renderSkuTable() {
  const q = (document.getElementById('skuSearch')?.value||'').toLowerCase();
  skuFiltered = filteredRows.filter(r =>
    !q || (r[CI.sku]+'').toLowerCase().includes(q) || (r[CI.desc]+'').toLowerCase().includes(q) || (r[CI.prov]+'').toLowerCase().includes(q)
  );

  if(skuSortCol >= 0) {
    skuFiltered = [...skuFiltered].sort((a,b) => {
      let va = a[skuSortCol], vb = b[skuSortCol];
      const na = parseFloat(va), nb = parseFloat(vb);
      if(!isNaN(na)&&!isNaN(nb)) return (na-nb)*skuSortDir;
      return String(va).localeCompare(String(vb))*skuSortDir;
    });
  }

  const total = skuFiltered.length;
  const maxPage = Math.max(0, Math.ceil(total/PAGE_SIZE)-1);
  if(skuPage > maxPage) skuPage = maxPage;
  const slice = skuFiltered.slice(skuPage*PAGE_SIZE, (skuPage+1)*PAGE_SIZE);

  document.getElementById('skuCount').textContent = total.toLocaleString('es-CL') + ' registros';
  document.getElementById('pageInfo').textContent = `Página ${skuPage+1} de ${Math.ceil(total/PAGE_SIZE)||1}`;
  document.getElementById('btnPrev').disabled = skuPage === 0;
  document.getElementById('btnNext').disabled = skuPage >= maxPage;

  const body = document.getElementById('skuBody');
  body.innerHTML = slice.map(r => {
    const dif = +r[CI.dif];
    const difCls = dif<0?'td-neg':dif>0?'td-pos':'td-zero';
    const vd = +r[CI.valDif];
    const vdCls = vd<0?'td-neg':vd>0?'td-pos':'td-zero';
    const motivo = (r[CI.motivo]||'').trim();
    const motTagCls = motivo==='45-SIN DIFERENCIAS '?'tag-ok': vd<0?'tag-fail': vd>0?'tag-warn':'tag-info';
    return `<tr>
      <td>${r[CI.fecha]}</td>
      <td>${r[CI.sku]}</td>
      <td title="${r[CI.desc]}">${(r[CI.desc]||'').slice(0,35)}</td>
      <td>${r[CI.prov]}</td>
      <td>${r[CI.suc]}</td>
      <td title="${r[CI.bod]}">${(r[CI.bod]||'').slice(0,22)}</td>
      <td>${(+r[CI.stockSap]).toLocaleString('es-CL')}</td>
      <td>${(+r[CI.fisico]).toLocaleString('es-CL')}</td>
      <td class="${difCls}">${dif.toLocaleString('es-CL')}</td>
      <td>${fmt.clpM(+r[CI.valInv])}</td>
      <td class="${vdCls}">${fmt.clp(vd)}</td>
      <td><span class="td-tag ${motTagCls}" title="${motivo}">${motivo.replace(/^\d+-/,'').slice(0,25)}</span></td>
      <td>${r[CI.mes]}</td>
    </tr>`;
  }).join('');
}

function sortSku(col) {
  if(skuSortCol===col) skuSortDir*=-1; else { skuSortCol=col; skuSortDir=1; }
  skuPage=0; renderSkuTable();
}
function changePage(delta) { skuPage+=delta; renderSkuTable(); }

