function loadFile(event) {
  const file = event.target.files[0]; if(!file) return;
  const reader = new FileReader();
  reader.onload = e => {
    const wb = XLSX.read(new Uint8Array(e.target.result),{type:'array'});
    const sheet = wb.Sheets[wb.SheetNames[0]];
    const raw = XLSX.utils.sheet_to_json(sheet,{header:1});
    const hdrs = raw[0];
    const idx = name => hdrs.indexOf(name);
    const COLS = ['Fecha','SKU','Descripción','Proveedor','SUCURSAL','TIPO DE BODEGA',
      'Stock SAP','Físico','Dif','Valor Inv.','Valor Dif','Motivo','Mes','Año','Cant SKU','SKU Dif',
      'Fecha de Vencimiento','UBICACIÓN'];

    function excelDate(n) {
      try {
        n = parseInt(n);
        if(n>0){ const d=new Date((n-25569)*86400000); return d.toISOString().slice(0,10); }
      } catch(e) {}
      return '';
    }

    allRows = raw.slice(1).map(row => {
      return COLS.map(c => {
        const i = idx(c);
        const v = i>=0 ? row[i] : '';
        if(['Stock SAP','Físico','Dif','Valor Inv.','Valor Dif','Cant SKU','SKU Dif'].includes(c))
          return parseFloat(v)||0;
        if(c==='Fecha' || c==='Fecha de Vencimiento') return excelDate(v);
        return v!=null ? String(v).trim() : '';
      });
    }).filter(r => {
      const mes = r[CI.mes];
      return ['febrero','marzo','abril','mayo'].includes((mes||'').toLowerCase().trim());
    });

    document.getElementById('lastUpdate').textContent = 'BD: ' + file.name.slice(-14,-5);
    populateFilters(allRows);
    applyFilters();
    alert('✓ BD actualizada: ' + allRows.length + ' registros cargados.');
  };
  reader.readAsArrayBuffer(file);
}

// ═══════════════════════════════════════════════════════
// SECTION: VENCIMIENTOS / CADUCIDADES
// ═══════════════════════════════════════════════════════
const TODAY = new Date(); TODAY.setHours(0,0,0,0);

function diasRestantes(fechaStr) {
  if(!fechaStr) return null;
  const d = new Date(fechaStr + 'T00:00:00');
  if(isNaN(d)) return null;
  return Math.round((d - TODAY) / 86400000);
}

function vencCategoria(dias) {
  if(dias === null) return null;
  if(dias < 0)    return 'VENCIDO';
  if(dias <= 30)  return 'CRITICO';
  if(dias <= 90)  return 'ALERTA';
  if(dias <= 180) return 'PROXIMO';
  return 'VIGENTE';
}

function vencBadge(d) {
  const cat = vencCategoria(d);
  if(!cat) return '';
  const map = {
    VENCIDO: ['vb-expired','⛔ VENCIDO'],
    CRITICO: ['vb-critico',`🔴 ${Math.abs(d)} días`],
    ALERTA:  ['vb-alerta', `🟡 ${d} días`],
    PROXIMO: ['vb-proximo',`🟢 ${d} días`],
    VIGENTE: ['vb-vigente',`✅ ${d} días`]
  };
  const [cls, txt] = map[cat];
  return `<span class="vbadge ${cls}">${txt}</span>`;
}

let vencFiltered = [], vencPage = 0, vencSortCol = 9, vencSortDir = 1;

function renderVencimientos() {
  const rows = filteredRows.filter(r => r[CI.venc] && r[CI.venc] !== '');
  const meses = [...new Set(filteredRows.map(r=>r[CI.mes]))].join(', ');
  document.getElementById('venc-period-tag').textContent = meses || '';

  const cats = { VENCIDO:[], CRITICO:[], ALERTA:[], PROXIMO:[], VIGENTE:[] };
  rows.forEach(r => {
    const d = diasRestantes(r[CI.venc]);
    const c = vencCategoria(d);
    if(c) cats[c].push({r, d});
  });

  const sumVal = cat => cats[cat].reduce((s,x)=>s+(+x.r[CI.valInv]||0),0);

  // KPI cards
  const kpiDefs = [
    { key:'VENCIDO', lbl:'Vencidos',            desc:'Fecha expirada',     cls:'e' },
    { key:'CRITICO', lbl:'Críticos ≤30 días',   desc:'Riesgo inmediato',   cls:'c' },
    { key:'ALERTA',  lbl:'Alerta 31–90 días',   desc:'Requiere atención',  cls:'a' },
    { key:'PROXIMO', lbl:'Próximos 91–180 días', desc:'Seguimiento activo', cls:'p' },
    { key:'VIGENTE', lbl:'Vigentes >180 días',   desc:'Sin urgencia',       cls:'v' },
  ];
  document.getElementById('vencKpiGrid').innerHTML = kpiDefs.map(k => `
    <div class="venc-kpi ${k.cls}">
      <span class="vk-lbl">${k.lbl}</span>
      <span class="vk-num">${cats[k.key].length}</span>
      <span class="vk-val">${fmt.clpM(sumVal(k.key))}</span>
      <span class="vk-lbl" style="margin-top:2px">${k.desc}</span>
    </div>`).join('');

  // Pie: SKUs por categoría
  const pieLabels = ['Vencido','Crítico ≤30d','Alerta 31–90d','Próximo 91–180d','Vigente >180d'];
  const pieData   = ['VENCIDO','CRITICO','ALERTA','PROXIMO','VIGENTE'].map(k=>cats[k].length);
  const pieColors = ['#f87171','#ef4444','#f59e0b','#22c55e','#4f9cf9'];

  mkChart('chartVencPie',{ type:'doughnut', data:{
    labels: pieLabels,
    datasets:[{ data:pieData, backgroundColor:pieColors, borderColor:'#111827', borderWidth:2 }]
  }, options:{ responsive:true, maintainAspectRatio:false,
    plugins:{ legend:{ display:true, position:'right',
      labels:{ color:'#94a3b8', font:{family:'IBM Plex Mono',size:9}, boxWidth:10, padding:8 } } }
  }});

  // Bar: valor por categoría
  mkChart('chartVencVal',{ type:'bar', data:{
    labels: pieLabels,
    datasets:[{ data:['VENCIDO','CRITICO','ALERTA','PROXIMO','VIGENTE'].map(k=>+(sumVal(k)/1e6).toFixed(2)),
      backgroundColor:pieColors.map(c=>c+'99'), borderColor:pieColors, borderWidth:1.5, borderRadius:6
    }]
  }, options:{ responsive:true, maintainAspectRatio:false,
    plugins:{ legend:{ display:false } },
    scales:{
      x:{ ticks:TICK_STYLE, grid:GRID_STYLE },
      y:{ ticks:TICK_STYLE, grid:GRID_STYLE, title:{ display:true, text:'Millones $', color:'#64748b', font:{size:9} } }
    }
  }});

  // Timeline: SKUs próximos a vencer por mes
  const monthMap = {};
  rows.forEach(r => {
    const d = diasRestantes(r[CI.venc]);
    if(d === null || d < 0) return;
    const dt = new Date(r[CI.venc]+'T00:00:00');
    const key = `${dt.getFullYear()}-${String(dt.getMonth()+1).padStart(2,'0')}`;
    if(!monthMap[key]) monthMap[key] = { count:0, val:0 };
    monthMap[key].count++;
    monthMap[key].val += +r[CI.valInv]||0;
  });
  const sortedMonths = Object.keys(monthMap).sort().slice(0,24);
  const mNames = ['Ene','Feb','Mar','Abr','May','Jun','Jul','Ago','Sep','Oct','Nov','Dic'];
  const monthLabels = sortedMonths.map(k => {
    const [y,m] = k.split('-');
    return `${mNames[+m-1]} ${y}`;
  });
  mkChart('chartVencTimeline',{ type:'bar', data:{
    labels: monthLabels,
    datasets:[
      { label:'N° SKUs', data:sortedMonths.map(k=>monthMap[k].count),
        backgroundColor:'rgba(79,156,249,.55)', borderColor:'#4f9cf9', borderWidth:1.5, borderRadius:4, yAxisID:'y' },
      { label:'Valor ($ M)', data:sortedMonths.map(k=>+(monthMap[k].val/1e6).toFixed(2)),
        type:'line', borderColor:'#f59e0b', backgroundColor:'rgba(245,158,11,.08)',
        borderWidth:2.5, pointRadius:4, pointBackgroundColor:'#f59e0b', fill:true, tension:.3, yAxisID:'y1' }
    ]
  }, options:{ responsive:true, maintainAspectRatio:false,
    plugins:{ legend:{ display:true, position:'top', labels:{ color:'#94a3b8', font:{family:'IBM Plex Mono',size:9}, boxWidth:10 } } },
    scales:{
      x:{ ticks:{...TICK_STYLE, maxRotation:40}, grid:GRID_STYLE },
      y:{ ticks:TICK_STYLE, grid:GRID_STYLE, title:{ display:true, text:'SKUs', color:'#64748b', font:{size:9} } },
      y1:{ position:'right', ticks:TICK_STYLE, grid:{ display:false },
           title:{ display:true, text:'$ M', color:'#64748b', font:{size:9} } }
    }
  }});

  renderVencTable();
}

function renderVencTable() {
  const q      = (document.getElementById('vencSearch')?.value||'').toLowerCase();
  const catFil = document.getElementById('vencFiltro')?.value || '';

  vencFiltered = filteredRows
    .filter(r => r[CI.venc] && r[CI.venc] !== '')
    .map(r => ({ r, d: diasRestantes(r[CI.venc]) }))
    .filter(({r, d}) => {
      if(catFil && vencCategoria(d) !== catFil) return false;
      if(q && !(r[CI.sku]+'').toLowerCase().includes(q) &&
              !(r[CI.desc]+'').toLowerCase().includes(q) &&
              !(r[CI.prov]+'').toLowerCase().includes(q)) return false;
      return true;
    });

  vencFiltered.sort((a,b) => {
    if(vencSortCol === 9)  return ((a.d??999999) - (b.d??999999)) * vencSortDir;
    if(vencSortCol === 10) return 0;
    const colMap = [CI.sku,CI.desc,CI.prov,CI.suc,CI.bod,CI.ubic,CI.fisico,CI.valInv,CI.venc];
    const ci = colMap[vencSortCol];
    const va=a.r[ci], vb=b.r[ci];
    const na=parseFloat(va), nb=parseFloat(vb);
    if(!isNaN(na)&&!isNaN(nb)) return (na-nb)*vencSortDir;
    return String(va).localeCompare(String(vb))*vencSortDir;
  });

  const total = vencFiltered.length;
  const maxPage = Math.max(0, Math.ceil(total/PAGE_SIZE)-1);
  if(vencPage>maxPage) vencPage=maxPage;
  const slice = vencFiltered.slice(vencPage*PAGE_SIZE,(vencPage+1)*PAGE_SIZE);

  document.getElementById('vencCount').textContent = total.toLocaleString('es-CL')+' registros';
  document.getElementById('vencPageInfo').textContent = `Página ${vencPage+1} de ${Math.ceil(total/PAGE_SIZE)||1}`;
  document.getElementById('btnVencPrev').disabled = vencPage===0;
  document.getElementById('btnVencNext').disabled = vencPage>=maxPage;

  document.getElementById('vencBody').innerHTML = slice.map(({r,d}) => {
    const diasNum = d ?? '—';
    const rowStyle = d!==null && d<0   ? 'background:rgba(248,113,113,.06)'
                   : d!==null && d<=30 ? 'background:rgba(239,68,68,.03)' : '';
    const diasColor = d!==null && d<0   ? 'color:#f87171;font-weight:800'
                    : d!==null && d<=30 ? 'color:#ef4444;font-weight:700'
                    : d!==null && d<=90 ? 'color:#f59e0b;font-weight:600' : '';
    return `<tr style="${rowStyle}">
      <td><strong>${r[CI.sku]}</strong></td>
      <td title="${r[CI.desc]}">${(r[CI.desc]||'').slice(0,42)}</td>
      <td>${r[CI.prov]}</td>
      <td>${r[CI.suc]}</td>
      <td title="${r[CI.bod]}">${(r[CI.bod]||'').slice(0,24)}</td>
      <td>${r[CI.ubic]||'—'}</td>
      <td>${(+r[CI.fisico]).toLocaleString('es-CL')}</td>
      <td>${fmt.clpM(+r[CI.valInv])}</td>
      <td style="font-family:'Syne',sans-serif;font-weight:600;${d!==null&&d<0?'color:#f87171':''}">${r[CI.venc]||'—'}</td>
      <td style="font-family:'Syne',sans-serif;font-size:14px;${diasColor}">${typeof diasNum==='number'?diasNum.toLocaleString('es-CL'):diasNum}</td>
      <td>${vencBadge(d)}</td>
    </tr>`;
  }).join('');
}

function sortVenc(col) {
  if(vencSortCol===col) vencSortDir*=-1; else { vencSortCol=col; vencSortDir=1; }
  vencPage=0; renderVencTable();
}
function changeVencPage(delta) { vencPage+=delta; renderVencTable(); }

function exportVencTable() {
  const headers = ['SKU','Descripción','Proveedor','Sucursal','Bodega','Ubicación','Físico','Valor Inv.','Fecha Vencimiento','Días Restantes','Estado'];
  const rows = vencFiltered.map(({r,d}) => [
    r[CI.sku], r[CI.desc], r[CI.prov], r[CI.suc], r[CI.bod], r[CI.ubic]||'',
    +r[CI.fisico], +r[CI.valInv], r[CI.venc], d??'', vencCategoria(d)||''
  ].map(v=>`"${String(v).replace(/"/g,"'")}"`).join(','));
  const csv = '\uFEFF' + headers.join(',') + '\n' + rows.join('\n');
  const blob = new Blob([csv],{type:'text/csv;charset=utf-8'});
  const a = document.createElement('a'); a.href=URL.createObjectURL(blob);
  a.download=`allendes_vencimientos_${new Date().toISOString().slice(0,10)}.csv`; a.click();
}
